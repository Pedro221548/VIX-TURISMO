rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper to check if user is the specific admin
    function isSuperAdmin() {
      return request.auth != null && 
             (request.auth.token.get('email', '') == "pedroass.11577@gmail.com" && request.auth.token.get('email_verified', false) == true ||
              request.auth.uid == "dC3g33pVLtThUTdPygKDfPPXLhe2");
    }

    // User profiles
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Public Collections - Allow anyone to read, only admin to write
    
    match /roteiros/{document=**} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    match /quick_posts/{document=**} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    match /sunset_locations/{document=**} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    match /moqueca_recipe/{document=**} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    match /experiences/{document=**} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    match /hero_data/{document=**} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    match /settings/{document=**} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    // Catch-all deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
