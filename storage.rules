rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      // Allow read for everyone
      allow read: if true;
      // Allow write only for admins
      allow write: if request.auth != null && 
        (request.auth.token.get('email', '') == "pedroass.11577@gmail.com" || 
         request.auth.uid == "dC3g33pVLtThUTdPygKDfPPXLhe2" ||
         request.auth.uid == "jCTLdTL2anfYkKJdRDcDgJHKtHl1"); // UID from the error message in previous turn
    }
  }
}
