{
  "entities": {
    "Store": {
      "title": "Store Configuration",
      "description": "Global settings for the store like name, logo, and colors.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The name of the store." },
        "logo": { "type": "string", "description": "URL to the store logo." },
        "colors": { "type": "object", "description": "Theme colors for the store." }
      },
      "required": ["name"]
    },
    "Product": {
      "title": "Product",
      "description": "A product available in the store.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Product name." },
        "description": { "type": "string", "description": "Product description." },
        "price": { "type": "number", "description": "Product price." },
        "image": { "type": "string", "description": "URL to product image." },
        "category": { "type": "string", "description": "Product category." }
      },
      "required": ["name", "price"]
    },
    "Banner": {
      "title": "Banner",
      "description": "Promotional banner for the store.",
      "type": "object",
      "properties": {
        "image": { "type": "string", "description": "URL to banner image." },
        "link": { "type": "string", "description": "Optional link for the banner." },
        "active": { "type": "boolean", "description": "Whether the banner is currently active." }
      },
      "required": ["image"]
    },
    "AnalyticsEvent": {
      "title": "Analytics Event",
      "description": "An event captured for analytics purposes.",
      "type": "object",
      "properties": {
        "type": { "type": "string", "description": "Type of event (e.g., click, search)." },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the event occurred." },
        "metadata": { "type": "object", "description": "Additional event data." }
      },
      "required": ["type", "timestamp"]
    },
    "User": {
      "title": "User Profile",
      "description": "Information about a registered user.",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "displayName": { "type": "string" }
      },
      "required": ["email", "role"]
    }
  },
  "firestore": {
    "/roteiros/{id}": {
      "schema": "Roteiro",
      "description": "Collection of travel itineraries."
    },
    "/quick_posts/{id}": {
      "schema": "QuickPost",
      "description": "Short social-media style posts."
    },
    "/sunset_locations/{id}": {
      "schema": "SunsetLocation",
      "description": "Best spots to watch the sunset."
    },
    "/moqueca_recipe/{id}": {
      "schema": "MoquecaRecipe",
      "description": "Traditional recipe data."
    },
    "/experiences/{id}": {
      "schema": "Experience",
      "description": "Local experiences and tours."
    },
    "/hero_data/{id}": {
      "schema": "HeroData",
      "description": "Homepage hero section content."
    },
    "/settings/{id}": {
      "schema": "Settings",
      "description": "Global app settings and contact info."
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles and roles."
    }
  }
}
