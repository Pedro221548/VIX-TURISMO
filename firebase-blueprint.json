{
  "entities": {
    "Roteiro": {
      "title": "Roteiro",
      "description": "A travel itinerary.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "price": { "type": "string" },
        "images": { "type": "array", "items": { "type": "string" } },
        "places": { "type": "array", "items": { "type": "string" } },
        "history": { "type": "string" },
        "gastronomy": { "type": "string" },
        "curiosities": { "type": "string" }
      },
      "required": ["title", "price"]
    },
    "GalleryImage": {
      "title": "Gallery Image",
      "description": "An image for the gallery section.",
      "type": "object",
      "properties": {
        "url": { "type": "string", "description": "URL of the image." },
        "caption": { "type": "string", "description": "Optional caption for the image." },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["url"]
    },
    "Settings": {
      "title": "Settings",
      "description": "Global app settings and contact info.",
      "type": "object",
      "properties": {
        "whatsapp": { "type": "string" },
        "instagram": { "type": "string" },
        "facebook": { "type": "string" },
        "email": { "type": "string" }
      }
    },
    "User": {
      "title": "User Profile",
      "description": "Information about a registered user.",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "displayName": { "type": "string" }
      },
      "required": ["email", "role"]
    }
  },
  "firestore": {
    "/roteiros/{id}": {
      "schema": "Roteiro",
      "description": "Collection of travel itineraries."
    },
    "/gallery/{id}": {
      "schema": "GalleryImage",
      "description": "Collection of gallery images."
    },
    "/settings/{id}": {
      "schema": "Settings",
      "description": "Global app settings and contact info."
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles and roles."
    }
  }
}
